# bench target 本地配置（含机器路径；由 target.json.example 复制而来，各自本地改不冲突）
# problems.json（gold 题库）仍入库——它是 benchmark 的"试卷+答案"，不是机器配置
eval/targets/*/target.json

# bench 本地配置（各自本地改，不入库，避免冲突；由 bench.yaml.example 复制而来，含 api_key）
bench.yaml

# agent-compare 报告：会话/思考本地不入库（防膨胀；conclusion/summary/config/aggregate/episode.json 入库）
eval/reports/agent-compare/*/arms/*/episodes/*/session.jsonl
eval/reports/agent-compare/*/arms/*/episodes/*/thinking.md

