# bench.yaml.example —— benchmark 全引擎可调项（模板，入库）
#
# 用法：复制为 bench.yaml 再改（bench.yaml 已 gitignore，不入库，各自本地改不冲突）：
#   cp bench.yaml.example bench.yaml
#
# 缺失 bench.yaml 时用 eval/config.py 内置 _DEFAULTS（与本模板一致）兜底，bench 照跑（但无 api_key）。
# 本文件就是本地唯一配置：api_key 也填这里（bench.yaml 不入库，不会泄密）。
# 配置加载：_DEFAULTS → bench.yaml（深合并覆盖）。

llm:
  api_key: your-glm-api-key-here     # GLM api key（open.bigmodel.cn）；或走 env AB_API_KEY / ~/.cc-connect/config.toml
  base_url: https://open.bigmodel.cn/api/anthropic    # agent + judge 共用（anthropic 兼容端点，一把 key/一个端点）
  model: glm-5.1                                       # 统一模型（agent + judge 都用这个）
  prices:                                              # $/Mtoken（占位，勿当真实成本；未知模型 → cost null）
    glm-5.1: {in: 0.70, out: 0.70}
    glm-5.2: {in: 0.70, out: 0.70}

agent:
  max_steps: 30          # run-until-answer backstop（防死循环；正常题自然收敛远在此之前）
  skill_max_steps: 30    # 同上（skills 臂不再单独收紧）
  tool_result_cap: 2000  # tool_result 序列化截断（防 session.jsonl 膨胀）
  read_cap: 2000         # read_file 截断 chars（两臂公平）

server:
  port: 8765             # bench web 前端端口

timeouts:                # 子进程超时默认（秒）
  probe: 10
  tool: 30
  long: 120
  run: 600
